# ─── Database (MySQL - cPanel) ───────────────────────────────────────────────
# Format: mysql://USERNAME:PASSWORD@localhost:3306/DATABASE_NAME
# Use a strong random password — generate with: openssl rand -base64 24
DATABASE_URL="mysql://crm_user:STRONG_RANDOM_PASSWORD_HERE@localhost:3306/persicore_crm"
# Connection pool size per Next.js instance (default: 10). For multi-instance deploys, keep total ≤ MySQL max_connections.
DATABASE_POOL_SIZE=10

# ─── JWT ─────────────────────────────────────────────────────────────────────
# Use a long random string (minimum 32 characters) — generate with: openssl rand -hex 32
JWT_SECRET="change-this-to-a-long-random-secret-minimum-32-characters"
# Separate secret for customer portal tokens — must be different from JWT_SECRET
PORTAL_JWT_SECRET="change-this-to-a-different-long-random-secret-minimum-32-chars"

# ─── App ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_NAME=Persicore CRM
NEXT_PUBLIC_APP_URL=https://crm.persicore.ir
NEXT_PUBLIC_USE_MOCK=false
NEXT_PUBLIC_API_URL=https://crm.persicore.ir/api

NODE_ENV=production
PORT=3000

# ─── SMTP Email ───────────────────────────────────────────────────────────────
# برای ارسال ایمیل فراموشی رمز پرتال مشتریان
SMTP_HOST=mail.persicore.ir
SMTP_PORT=587
SMTP_USER=noreply@persicore.ir
SMTP_PASS=your_email_password

# ─── File Storage ────────────────────────────────────────────────────────────
# Options: "local" (default), "s3", "r2", "minio"
STORAGE_PROVIDER=local

# S3 (AWS)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=me-south-1
# AWS_BUCKET=persicore-crm

# Cloudflare R2
# CLOUDFLARE_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET=persicore-crm
# R2_PUBLIC_URL=https://files.persicore.ir

# MinIO (self-hosted S3-compatible)
# MINIO_ENDPOINT=https://minio.persicore.ir
# MINIO_ACCESS_KEY=minioadmin
# MINIO_SECRET_KEY=miniopassword
# MINIO_BUCKET=persicore-crm
# MINIO_REGION=us-east-1
# MINIO_PUBLIC_URL=https://minio.persicore.ir

# ─── ZarinPal Payment ─────────────────────────────────────────────────────────
# دریافت از: https://www.zarinpal.com/pg/dashboard
ZARINPAL_MERCHANT_ID="xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"
# برای تست از sandbox استفاده کنید (true) و برای production روی false بگذارید
ZARINPAL_SANDBOX="true"

# ─── Redis (rate limiting — multi-instance safe) ─────────────────────────────
# گزینه ۱ — Upstash Cloud (رایگان، بدون نیاز به سرور): https://console.upstash.com
# گزینه ۲ — Self-hosted با HTTP proxy:
#   docker run -p 8079:8079 \
#     -e SRH_MODE=env \
#     -e SRH_TOKEN=my-secret-token \
#     -e SRH_CONNECTION_STRING="redis://localhost:6379" \
#     hiett/serverless-redis-http:latest
#   سپس: UPSTASH_REDIS_REST_URL=http://localhost:8079
#          UPSTASH_REDIS_REST_TOKEN=my-secret-token
#
# اگر تنظیم نشود، middleware به حالت fail-open می‌رود (بدون rate limit).
UPSTASH_REDIS_REST_URL="https://your-instance.upstash.io"
UPSTASH_REDIS_REST_TOKEN="your-token-here"

# ─── Sentry Error Tracking ────────────────────────────────────────────────────
# دریافت از: https://sentry.io → Settings → Projects → Client Keys
NEXT_PUBLIC_SENTRY_DSN=""
SENTRY_DSN=""
SENTRY_ORG="your-org"
SENTRY_PROJECT="persicore-crm"
SENTRY_AUTH_TOKEN=""
