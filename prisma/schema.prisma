// ─── CRM Additions ──────────────────────────────────────────────────
// ═══════════════════════════════════════════════════════════════════

model CallLog {
  id         String   @id @default(cuid())
  tenantId   String?
  entityType String // lead | client
  entityId   String
  direction  String   @default("outbound") // inbound | outbound
  outcome    String   @default("no_answer") // answered | no_answer | busy | voicemail | meeting_set
  duration   Int?
  notes      String?  @db.Text
  userId     String
  calledAt   DateTime @default(now())
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([entityType, entityId])
}

model CustomerSegment {
  id          String   @id @default(cuid())
  tenantId    String?
  name        String
  description String?  @db.Text
  color       String   @default("#8B5CF6")
  filters     Json     @default("{}")
  clientIds   Json     @default("[]")
  autoUpdate  Boolean  @default(false)
  createdById String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  createdBy User @relation("SegmentCreator", fields: [createdById], references: [id])
}

// ═══════════════════════════════════════════════════════════════════
// ─── HR ─────────────────────────────────────────────────────────────
// ═══════════════════════════════════════════════════════════════════

model OrgNode {
  id         String   @id @default(cuid())
  tenantId   String?
  userId     String   @unique
  parentId   String?
  position   String?
  department String?
  order      Int      @default(0)
  createdAt  DateTime @default(now())

  user     User      @relation(fields: [userId], references: [id])
  parent   OrgNode?  @relation("OrgHierarchy", fields: [parentId], references: [id])
  children OrgNode[] @relation("OrgHierarchy")
}

model EmployeeContract {
  id         String    @id @default(cuid())
  tenantId   String?
  userId     String
  type       String    @default("full_time") // full_time | part_time | contract | internship
  startDate  DateTime
  endDate    DateTime?
  salary     Int       @default(0)
  position   String
  department String?
  fileUrl    String?
  status     String    @default("active") // active | expired | terminated
  notes      String?   @db.Text
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id])
}

model Attendance {
  id        String    @id @default(cuid())
  userId    String
  date      DateTime
  checkIn   DateTime?
  checkOut  DateTime?
  status    String    @default("present") // present | absent | late | half_day | holiday | leave
  notes     String?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, date])
  @@index([userId, date])
}

model LeaveRequest {
  id           String    @id @default(cuid())
  userId       String
  type         String    @default("annual") // annual | sick | personal | maternity | unpaid
  startDate    DateTime
  endDate      DateTime
  days         Float     @default(1)
  reason       String?   @db.Text
  status       String    @default("pending") // pending | approved | rejected
  reviewedById String?
  reviewedAt   DateTime?
  reviewNote   String?
  createdAt    DateTime  @default(now())

  user       User  @relation("LeaveEmployee", fields: [userId], references: [id])
  reviewedBy User? @relation("LeaveReviewer", fields: [reviewedById], references: [id])
}

model PerformanceKPI {
  id           String   @id @default(cuid())
  userId       String
  period       String
  goals        Json     @default("[]")
  score        Float?
  grade        String?
  reviewedById String?
  reviewNotes  String?  @db.Text
  status       String   @default("draft") // draft | submitted | reviewed
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user       User  @relation("KPIEmployee", fields: [userId], references: [id])
  reviewedBy User? @relation("KPIReviewer", fields: [reviewedById], references: [id])
}

model EmployeeBenefit {
  id        String    @id @default(cuid())
  userId    String
  type      String    @default("insurance") // insurance | loan | allowance | other
  title     String
  amount    Int?
  startDate DateTime
  endDate   DateTime?
  notes     String?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id])
}

model TrainingCourse {
  id          String   @id @default(cuid())
  tenantId    String?
  title       String
  description String?  @db.Text
  instructor  String?
  duration    Int?
  category    String   @default("technical")
  fileUrl     String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  enrollments TrainingEnrollment[]
}

model TrainingEnrollment {
  id          String    @id @default(cuid())
  tenantId    String?
  courseId    String
  userId      String
  enrolledAt  DateTime  @default(now())
  completedAt DateTime?
  score       Int?
  certificate String?

  course TrainingCourse @relation(fields: [courseId], references: [id], onDelete: Cascade)
  user   User           @relation(fields: [userId], references: [id])

  @@unique([courseId, userId])
}

model JobPosting {
  id           String    @id @default(cuid())
  tenantId     String?
  title        String
  department   String?
  type         String    @default("full_time")
  location     String?
  description  String?   @db.LongText
  requirements String?   @db.Text
  salaryFrom   Int?
  salaryTo     Int?
  status       String    @default("open") // open | closed | draft
  deadline     DateTime?
  createdById  String
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  createdBy    User             @relation("JobCreator", fields: [createdById], references: [id])
  applications JobApplication[]
}

model JobApplication {
  id           String   @id @default(cuid())
  jobId        String
  fullName     String
  email        String
  phone        String?
  resumeUrl    String?
  coverLetter  String?  @db.Text
  status       String   @default("new") // new | reviewing | interview | offer | rejected | hired
  reviewedById String?
  notes        String?  @db.Text
  appliedAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  job        JobPosting @relation(fields: [jobId], references: [id], onDelete: Cascade)
  reviewedBy User?      @relation("ApplicationReviewer", fields: [reviewedById], references: [id])
}

// ═══════════════════════════════════════════════════════════════════
// ─── ERP – Accounting ───────────────────────────────────────────────
// ═══════════════════════════════════════════════════════════════════

model ChartOfAccount {
  id          String   @id @default(cuid())
  tenantId    String?
  code        String   @unique
  name        String
  nameFa      String
  type        String // asset | liability | equity | revenue | expense
  parentId    String?
  isActive    Boolean  @default(true)
  description String?
  createdAt   DateTime @default(now())

  parent        ChartOfAccount?  @relation("AccountHierarchy", fields: [parentId], references: [id])
  children      ChartOfAccount[] @relation("AccountHierarchy")
  debitEntries  LedgerEntry[]    @relation("DebitAccount")
  creditEntries LedgerEntry[]    @relation("CreditAccount")
  journalLines  JournalLine[]    @relation("JournalLineAccount")
  budgets       Budget[]
}

model LedgerEntry {
  id              String   @id @default(cuid())
  tenantId        String?
  date            DateTime
  description     String   @db.Text
  debitAccountId  String
  creditAccountId String
  amount          Int
  reference       String?
  entityType      String?
  entityId        String?
  createdById     String
  createdAt       DateTime @default(now())

  debitAccount  ChartOfAccount @relation("DebitAccount", fields: [debitAccountId], references: [id])
  creditAccount ChartOfAccount @relation("CreditAccount", fields: [creditAccountId], references: [id])
  createdBy     User           @relation("LedgerCreator", fields: [createdById], references: [id])

  @@index([date])
  @@index([entityType, entityId])
}

// ─── سند حسابداری چندسطری ─────────────────────────────────────────────────────
model JournalVoucher {
  id          String   @id @default(cuid())
  tenantId    String?
  number      Int
  date        DateTime
  description String   @db.Text
  status      String   @default("draft") // draft | posted | cancelled
  createdById String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  lines     JournalLine[]
  createdBy User          @relation("JournalCreator", fields: [createdById], references: [id])

  @@index([date])
  @@index([tenantId, number])
}

model JournalLine {
  id        String  @id @default(cuid())
  voucherId String
  accountId String
  debit     Int     @default(0)
  credit    Int     @default(0)
  note      String?

  voucher JournalVoucher @relation(fields: [voucherId], references: [id], onDelete: Cascade)
  account ChartOfAccount @relation("JournalLineAccount", fields: [accountId], references: [id])

  @@index([voucherId])
}

model BankAccount {
  id            String   @id @default(cuid())
  tenantId      String?
  name          String
  bankName      String
  accountNumber String
  iban          String?
  currency      String   @default("IRR")
  balance       Int      @default(0)
  isActive      Boolean  @default(true)
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  transactions BankTransaction[]
  checks       BankCheck[]
}

model BankTransaction {
  id             String    @id @default(cuid())
  tenantId       String?
  accountId      String
  type           String    @default("credit") // credit | debit
  amount         Int
  description    String
  reference      String?
  date           DateTime
  balance        Int       @default(0)
  entityType     String?
  entityId       String?
  reconciled     Boolean   @default(false)
  reconciledAt   DateTime?
  createdAt      DateTime  @default(now())

  account BankAccount @relation(fields: [accountId], references: [id])

  @@index([accountId, date])
  @@index([tenantId, reconciled])
}

model BankCheck {
  id          String   @id @default(cuid())
  accountId   String?
  type        String   @default("issued") // issued | received
  payee       String
  amount      Int
  checkNumber String
  dueDate     DateTime
  issuedDate  DateTime @default(now())
  status      String   @default("pending") // pending | cleared | bounced | cancelled
  description String?
  entityType  String?
  entityId    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  account BankAccount? @relation(fields: [accountId], references: [id])

  @@index([dueDate])
}

model FixedAsset {
  id               String    @id @default(cuid())
  tenantId         String?
  name             String
  category         String    @default("equipment")
  purchaseDate     DateTime
  purchasePrice    Int
  currentValue     Int
  depreciationRate Float     @default(20)
  location         String?
  serialNumber     String?
  warrantyExpiry   DateTime?
  status           String    @default("active") // active | sold | disposed | maintenance
  notes            String?   @db.Text
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
}

model TaxRecord {
  id         String    @id @default(cuid())
  tenantId   String?
  period     String
  type       String    @default("vat") // vat | income | other
  totalSales Int       @default(0)
  taxableAmt Int       @default(0)
  taxRate    Float     @default(9)
  taxAmount  Int       @default(0)
  exemptions Int       @default(0)
  status     String    @default("draft") // draft | filed | paid
  dueDate    DateTime?
  paidAt     DateTime?
  notes      String?   @db.Text
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
}

// ═══════════════════════════════════════════════════════════════════
// ─── Legal Additions ─────────────────────────────────────────────────
