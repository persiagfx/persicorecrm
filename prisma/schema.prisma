  tenantId  String?
  caseId    String
  date      DateTime
  court     String
  judge     String?
  notes     String?  @db.Text
  outcome   String?
  status    String   @default("scheduled") // scheduled | completed | postponed | cancelled
  createdAt DateTime @default(now())

  case LegalCase @relation(fields: [caseId], references: [id], onDelete: Cascade)

  @@index([caseId])
}

model LegalDeadline {
  id           String    @id @default(cuid())
  tenantId     String?
  caseId       String?
  contractId   String?
  title        String
  dueDate      DateTime
  type         String    @default("other")
  priority     String    @default("medium")
  isCompleted  Boolean   @default(false)
  completedAt  DateTime?
  assignedToId String?
  notes        String?
  createdAt    DateTime  @default(now())

  assignedTo User? @relation("DeadlineAssignee", fields: [assignedToId], references: [id])

  @@index([dueDate])
}

// ═══════════════════════════════════════════════════════════════════
// ─── Marketing Additions ─────────────────────────────────────────────
// ═══════════════════════════════════════════════════════════════════

