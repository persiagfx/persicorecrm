generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ─── User ────────────────────────────────────────────────────────────
model User {
  id               String    @id @default(cuid())
  name             String
  email            String?   @unique
  phone            String?   @unique
  passwordHash     String?
  avatar           String?
  role             String    @default("sales_rep")
  color            String    @default("gold")
  walletBalance    Int       @default(0)
  joinedAt         DateTime  @default(now())
  isActive         Boolean   @default(true)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  tenantId         String?
  lastLoginAt      DateTime?
  resetToken       String?   @unique
  resetTokenExpiry DateTime?
  totpSecret       String?
  totpEnabled      Boolean   @default(false)

  tenant                  Tenant?              @relation(fields: [tenantId], references: [id])
  leads                   Lead[]               @relation("LeadAssignee")
  timeEntries             TimeEntry[]
  activityLogs            ActivityLog[]
  reminders               Reminder[]
  notifications           Notification[]
  commissions             Commission[]
  payrollRecords          PayrollRecord[]
  salaryAdvances          SalaryAdvance[]
  wikiArticles            WikiArticle[]
  meetingsCreated         Meeting[]            @relation("MeetingCreator")
  meetingAttendees        MeetingAttendee[]
  expenses                Expense[]
  walletTxs               WalletTransaction[]
  blogPosts               BlogPost[]           @relation("BlogAuthor")
  approvedExpenses        Expense[]            @relation("ExpenseApprover")
  deployedChecklists      DeployChecklist[]    @relation("ChecklistDeployer")
  uploadedFiles           FileItem[]           @relation("FileUploader")
  createdCampaigns        Campaign[]           @relation("CampaignCreator")
  createdForms            SurveyForm[]         @relation("FormCreator")
  legalCasesAsLawyer      LegalCase[]          @relation("CaseLawyer")
  createdLegalContracts   LegalContract[]      @relation("LegalContractCreator")
  portalMessages          PortalMessage[]      @relation("CRMUserMessage")
  // CRM
  callLogs                CallLog[]
  customerSegments        CustomerSegment[]    @relation("SegmentCreator")
  // HR
  orgNode                 OrgNode?
  employeeContracts       EmployeeContract[]
  attendances             Attendance[]
  leaveRequests           LeaveRequest[]       @relation("LeaveEmployee")
  leaveReviews            LeaveRequest[]       @relation("LeaveReviewer")
  performanceKPIs         PerformanceKPI[]     @relation("KPIEmployee")
  kpiReviews              PerformanceKPI[]     @relation("KPIReviewer")
  benefits                EmployeeBenefit[]
  trainingEnrollments     TrainingEnrollment[]
  jobPostings             JobPosting[]         @relation("JobCreator")
  jobApplicationsReviewed JobApplication[]     @relation("ApplicationReviewer")
  shiftAssignments        ShiftAssignment[]
  onboardings             EmployeeOnboarding[]
  // ERP
  ledgerEntries           LedgerEntry[]        @relation("LedgerCreator")
  journalVouchers         JournalVoucher[]     @relation("JournalCreator")
  // Legal
  legalDocuments          LegalDocument[]      @relation("LegalDocUploader")
  legalDeadlines          LegalDeadline[]      @relation("DeadlineAssignee")
  // Marketing
  utmLinks                UTMLink[]            @relation("UTMLinkCreator")
  emailCampaigns          EmailCampaign[]      @relation("EmailCampaignCreator")
  personas                MarketingPersona[]   @relation("PersonaCreator")
  abTests                 ABTest[]             @relation("ABTestCreator")
  // New features
  sessions                UserSession[]
  pushSubscriptions       PushSubscription[]
  automationRules         AutomationRule[]     @relation("AutomationCreator")
  salesFunnels            SalesFunnel[]        @relation("FunnelCreator")
  customerJourneys        CustomerJourney[]    @relation("JourneyCreator")
  savedReports            SavedReport[]        @relation("ReportCreator")
}

// ─── Client ──────────────────────────────────────────────────────────
model Client {
  id                String    @id @default(cuid())
  tenantId          String?
  companyName       String
  contactName       String
  contactPhone      String
  contactEmail      String?
  address           String?
  website           String?
  status            String    @default("active")
  tags              Json      @default("[]")
  totalRevenue      Int       @default(0)
  projectCount      Int       @default(0)
  lastInteractionAt DateTime?
  anniversaryDate   DateTime?
  notes             String?   @db.Text
  avatar            String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  projects    Project[]
  invoices    Invoice[]
  reminders   Reminder[]
  meetings    Meeting[]
  contracts   Contract[]
  leads       Lead[]
  legalCases  LegalCase[]
  portalUsers PortalUser[]

  @@index([tenantId])
  @@index([tenantId, createdAt(sort: Desc)])
}

// ─── Lead ────────────────────────────────────────────────────────────
model Lead {
  id                    String    @id @default(cuid())
  tenantId              String?
  companyName           String
  contactName           String
  contactPhone          String
  contactEmail          String?
  estimatedValue        Int       @default(0)
  conversionProbability Int       @default(0)
  status                String    @default("new")
  columnId              String    @default("new")
  assigneeId            String?
  tags                  Json      @default("[]")
  dueDate               DateTime?
  notes                 String?   @db.Text
  source                String?
  winLossCategory       String?
  winLossDescription    String?   @db.Text
  competitorName        String?
  clientId              String?
  duplicateOfId         String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  assignee   User?          @relation("LeadAssignee", fields: [assigneeId], references: [id])
  client     Client?        @relation(fields: [clientId], references: [id])
  activities LeadActivity[]
  reminders  Reminder[]

  @@index([tenantId])
  @@index([tenantId, createdAt(sort: Desc)])
  @@index([tenantId, status])
  @@index([assigneeId])
}

model LeadActivity {
  id        String   @id @default(cuid())
  leadId    String
  type      String   @default("note")
  content   String   @db.Text
  authorId  String
  createdAt DateTime @default(now())

  lead Lead @relation(fields: [leadId], references: [id], onDelete: Cascade)
}

// ─── Project ─────────────────────────────────────────────────────────
model Project {
  id          String    @id @default(cuid())
  tenantId    String?
  name        String
  clientId    String
  description String?   @db.Text
  status      String    @default("planning")
  progress    Int       @default(0)
  budget      Int       @default(0)
  spent       Int       @default(0)
  startDate   DateTime
  deadline    DateTime
  completedAt DateTime?
  memberIds   Json      @default("[]")
  tags        Json      @default("[]")
  colorHash   String    @default("from-violet-500 to-purple-500")
  repoUrl     String?
  techDocs    Json      @default("[]")
  servers     Json      @default("[]")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  client           Client            @relation(fields: [clientId], references: [id])
  tasks            Task[]
  timeEntries      TimeEntry[]
  invoices         Invoice[]
  milestones       Milestone[]
  deployChecklists DeployChecklist[]
  contracts        Contract[]
  meetings         Meeting[]

  @@index([tenantId])
  @@index([tenantId, createdAt(sort: Desc)])
  @@index([tenantId, status])
}

// ─── Task ────────────────────────────────────────────────────────────
model Task {
  id             String    @id @default(cuid())
  projectId      String
  parentId       String?
  title          String
  description    String?   @db.Text
  status         String    @default("backlog")
  priority       String    @default("medium")
  assigneeIds    Json      @default("[]")
  tags           Json      @default("[]")
  dueDate        DateTime?
  startDate      DateTime?
  estimatedHours Float?
  trackedSeconds Int       @default(0)
  order          Int       @default(0)
  columnId       String?
  dependencyIds  Json      @default("[]")
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  project     Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  timeEntries TimeEntry[]
  comments    TaskComment[]
}

model TaskComment {
  id        String   @id @default(cuid())
  taskId    String
  content   String   @db.Text
  authorId  String
  createdAt DateTime @default(now())

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
}

model Milestone {
  id          String    @id @default(cuid())
  projectId   String
  title       String
  description String?   @db.Text
  dueDate     DateTime
  completedAt DateTime?
  color       String?
  createdAt   DateTime  @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model DeployChecklist {
  id           String    @id @default(cuid())
  projectId    String
  environment  String    @default("staging")
  items        Json      @default("[]")
  deployedAt   DateTime?
  deployedById String?
  createdAt    DateTime  @default(now())

  project    Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  deployedBy User?   @relation("ChecklistDeployer", fields: [deployedById], references: [id])
}

// ─── Time Tracking ───────────────────────────────────────────────────
model TimeEntry {
  id              String    @id @default(cuid())
  taskId          String?
  projectId       String
  userId          String
  startedAt       DateTime
  endedAt         DateTime?
  durationSeconds Int       @default(0)
  notes           String?
  isRunning       Boolean   @default(false)
  createdAt       DateTime  @default(now())

  task    Task?   @relation(fields: [taskId], references: [id], onDelete: SetNull)
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id])
}

// ─── Invoice ─────────────────────────────────────────────────────────
model Invoice {
  id                     String    @id @default(cuid())
  tenantId               String?
  invoiceNumber          String    @unique
  type                   String    @default("invoice")
  clientId               String
  projectId              String?
  items                  Json      @default("[]")
  subtotal               Int       @default(0)
  taxRate                Float     @default(9)
  taxAmount              Int       @default(0)
  discount               Int       @default(0)
  total                  Int       @default(0)
  status                 String    @default("draft")
  issuedAt               DateTime  @default(now())
  dueDate                DateTime
  paidAt                 DateTime?
  notes                  String?   @db.Text
  isRecurring            Boolean   @default(false)
  recurringInterval      String?
  nextInvoiceDate        DateTime?
  // Admin signature
  adminSignatureDataUrl  String?   @db.LongText
  adminSignedAt          DateTime?
  // Client signature (portal signing)
  signToken              String?   @unique
  clientSignatureDataUrl String?   @db.LongText
  clientSignedAt         DateTime?
  clientSignedIp         String?
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt

  client       Client              @relation(fields: [clientId], references: [id])
  project      Project?            @relation(fields: [projectId], references: [id])
  installments Installment[]
  commissions  CommissionInvoice[]

  @@index([tenantId])
  @@index([tenantId, createdAt(sort: Desc)])
  @@index([tenantId, status])
  @@index([clientId])
}

model Installment {
  id            String    @id @default(cuid())
  invoiceId     String
  amount        Int
  dueDate       DateTime
  paidAt        DateTime?
  paidAmount    Int?
  paymentMethod String?
  reference     String?
  notes         String?
  status        String    @default("pending")
  createdAt     DateTime  @default(now())

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
}

// ─── Expense ─────────────────────────────────────────────────────────
model Expense {
  id             String    @id @default(cuid())
  tenantId       String?
  title          String
  amount         Int
  category       String    @default("other")
  date           DateTime
  paidById       String
  receipt        String?
  notes          String?
  approvalStatus String    @default("pending")
  approvedById   String?
  approvedAt     DateTime?
  createdAt      DateTime  @default(now())

  paidBy     User  @relation(fields: [paidById], references: [id])
  approvedBy User? @relation("ExpenseApprover", fields: [approvedById], references: [id])

  @@index([tenantId])
  @@index([tenantId, createdAt(sort: Desc)])
  @@index([tenantId, category])
}

// ─── Contract ────────────────────────────────────────────────────────
model ContractTemplate {
  id        String   @id @default(cuid())
  tenantId  String?
  name      String
  content   String   @db.LongText
  variables Json     @default("[]")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  contracts Contract[]
}

model Contract {
  id                    String    @id @default(cuid())
  tenantId              String?
  templateId            String?
  clientId              String
  projectId             String?
  title                 String
  content               String    @db.LongText
  status                String    @default("draft")
  // Admin signature
  adminSignedAt         DateTime?
  adminSignatureDataUrl String?   @db.LongText
  // Client signature
  signToken             String?   @unique
  signedAt              DateTime?
  signedIp              String?
  signatureDataUrl      String?   @db.LongText
  sentAt                DateTime?
  expiresAt             DateTime?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  template ContractTemplate? @relation(fields: [templateId], references: [id])
  client   Client            @relation(fields: [clientId], references: [id])
  project  Project?          @relation(fields: [projectId], references: [id])
}

// ─── Ticket ──────────────────────────────────────────────────────────
model Ticket {
  id          String    @id @default(cuid())
  tenantId    String?
  title       String
  description String?   @db.Text
  status      String    @default("open")
  priority    String    @default("medium")
  reporterId  String
  assigneeId  String?
  projectId   String?
  tags        Json      @default("[]")
  resolvedAt  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  comments TicketComment[]

  @@index([tenantId])
  @@index([tenantId, createdAt(sort: Desc)])
  @@index([tenantId, status])
  @@index([assigneeId])
}

model TicketComment {
  id        String   @id @default(cuid())
  ticketId  String
  content   String   @db.Text
  authorId  String
  createdAt DateTime @default(now())

  ticket Ticket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
}

// ─── Wiki ────────────────────────────────────────────────────────────
model WikiFolder {
  id        String   @id @default(cuid())
  tenantId  String?
  name      String
  parentId  String?
  order     Int      @default(0)
  createdAt DateTime @default(now())

  articles WikiArticle[]
}

model WikiArticle {
  id        String   @id @default(cuid())
  folderId  String
  title     String
  content   String   @db.LongText
  authorId  String
  isPinned  Boolean  @default(false)
  tags      Json     @default("[]")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  folder WikiFolder @relation(fields: [folderId], references: [id], onDelete: Cascade)
  author User       @relation(fields: [authorId], references: [id])
}

// ─── File ────────────────────────────────────────────────────────────
model FileFolder {
  id        String   @id @default(cuid())
  tenantId  String?
  name      String
  parentId  String?
  projectId String?
  createdAt DateTime @default(now())

  files FileItem[]
}

model FileItem {
  id             String   @id @default(cuid())
  name           String
  type           String
  size           Int      @default(0)
  folderId       String?
  projectId      String?
  uploadedById   String
  url            String
  thumbnailUrl   String?
  version        Int      @default(1)
  approvalStatus String   @default("pending")
  designComments Json     @default("[]")
  createdAt      DateTime @default(now())

  folder     FileFolder? @relation(fields: [folderId], references: [id], onDelete: SetNull)
  uploadedBy User        @relation("FileUploader", fields: [uploadedById], references: [id])
}

// ─── Activity Log ────────────────────────────────────────────────────
model ActivityLog {
  id          String   @id @default(cuid())
  tenantId    String?
  actorId     String
  action      String
  entityType  String
  entityId    String
  entityName  String
  description String   @db.Text
  metadata    Json?
  createdAt   DateTime @default(now())

  actor User @relation(fields: [actorId], references: [id])

  @@index([entityType, entityId])
  @@index([tenantId, createdAt(sort: Desc)])
  @@index([actorId])
}

// ─── Notification ────────────────────────────────────────────────────
model Notification {
  id         String   @id @default(cuid())
  userId     String
  type       String
  title      String
  body       String   @db.Text
  entityId   String?
  entityType String?
  isRead     Boolean  @default(false)
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@index([userId, createdAt(sort: Desc)])
}

// ─── Reminder ────────────────────────────────────────────────────────
model Reminder {
  id          String   @id @default(cuid())
  userId      String
  leadId      String?
  clientId    String?
  title       String
  notes       String?  @db.Text
  dueDate     DateTime
  isCompleted Boolean  @default(false)
  createdAt   DateTime @default(now())

  user   User    @relation(fields: [userId], references: [id])
  lead   Lead?   @relation(fields: [leadId], references: [id])
  client Client? @relation(fields: [clientId], references: [id])
}

// ─── Meeting ─────────────────────────────────────────────────────────
model Meeting {
  id               String   @id @default(cuid())
  tenantId         String?
  title            String
  type             String   @default("internal")
  status           String   @default("scheduled")
  startAt          DateTime
  endAt            DateTime
  location         String?
  meetingUrl       String?
  agenda           String?  @db.Text
  minutes          String?  @db.Text
  relatedProjectId String?
  relatedClientId  String?
  isPrivate        Boolean  @default(false)
  createdById      String
  actionItems      Json     @default("[]")
  createdAt        DateTime @default(now())

  createdBy User              @relation("MeetingCreator", fields: [createdById], references: [id])
  project   Project?          @relation(fields: [relatedProjectId], references: [id])
  client    Client?           @relation(fields: [relatedClientId], references: [id])
  attendees MeetingAttendee[]
}

model MeetingAttendee {
  id        String @id @default(cuid())
  meetingId String
  userId    String

  meeting Meeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id])

  @@unique([meetingId, userId])
}

// ─── Service / Product ───────────────────────────────────────────────
model ServiceItem {
  id           String   @id @default(cuid())
  tenantId     String?
  code         String   @unique
  name         String
  category     String   @default("other")
  defaultPrice Int      @default(0)
  unit         String   @default("hour")
  taxRate      Float    @default(9)
  description  String?  @db.Text
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
}

// ─── Payroll ─────────────────────────────────────────────────────────
model PayrollRecord {
  id                  String    @id @default(cuid())
  tenantId            String?
  userId              String
  period              String
  baseSalary          Int       @default(0)
  overtimePay         Int       @default(0)
  travelAllowance     Int       @default(0)
  housingAllowance    Int       @default(0)
  bonus               Int       @default(0)
  deductions          Int       @default(0)
  taxAmount           Int       @default(0)
  insuranceDeduction  Int       @default(0)
  loanDeduction       Int       @default(0)
  netPay              Int       @default(0)
  workingDays         Int       @default(22)
  presentDays         Int       @default(22)
  leaveDays           Int       @default(0)
  overtimeHours       Float     @default(0)
  status              String    @default("draft")
  paidAt              DateTime?
  notes               String?   @db.Text
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id])

  @@index([tenantId, period])
  @@unique([tenantId, userId, period])
}

model SalaryAdvance {
  id           String    @id @default(cuid())
  tenantId     String?
  userId       String
  amount       Int
  reason       String
  description  String?   @db.Text
  neededAt     DateTime
  status       String    @default("pending")
  reviewedById String?
  reviewNote   String?
  reviewedAt   DateTime?
  paidAt       DateTime?
  createdAt    DateTime  @default(now())

  user User @relation(fields: [userId], references: [id])
}

// ─── Commission ──────────────────────────────────────────────────────
model Commission {
  id           String    @id @default(cuid())
  tenantId     String?
  userId       String
  period       String
  totalRevenue Int       @default(0)
  percentage   Float     @default(0)
  amount       Int       @default(0)
  status       String    @default("pending")
  paidAt       DateTime?
  createdAt    DateTime  @default(now())

  user     User                @relation(fields: [userId], references: [id])
  invoices CommissionInvoice[]
}

model CommissionInvoice {
  commissionId String
  invoiceId    String

  commission Commission @relation(fields: [commissionId], references: [id], onDelete: Cascade)
  invoice    Invoice    @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@id([commissionId, invoiceId])
}

// ─── Wallet ──────────────────────────────────────────────────────────
model WalletTransaction {
  id          String   @id @default(cuid())
  userId      String
  type        String   @default("credit")
  amount      Int
  description String
  projectId   String?
  invoiceId   String?
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}

// ─── Marketing ───────────────────────────────────────────────────────
model Campaign {
  id                String    @id @default(cuid())
  tenantId          String?
  title             String
  channel           String    @default("other")
  status            String    @default("draft")
  budget            Int       @default(0)
  startDate         DateTime
  endDate           DateTime?
  metrics           Json      @default("{\"impressions\":0,\"clicks\":0,\"conversions\":0,\"spend\":0,\"revenue\":0}")
  targetAudience    String?
  description       String?   @db.Text
  progressNotes     Json      @default("[]")
  targetROI         Float?
  targetConversions Int?
  createdById       String
  createdAt         DateTime  @default(now())

  contentPieces ContentPiece[]
  createdBy     User           @relation("CampaignCreator", fields: [createdById], references: [id])
}

model ContentPiece {
  id          String    @id @default(cuid())
  title       String
  type        String    @default("blog")
  channel     String    @default("other")
  status      String    @default("idea")
  scheduledAt DateTime?
  publishedAt DateTime?
  assigneeId  String
  campaignId  String?
  url         String?
  notes       String?
  body        String?   @db.LongText
  archivedAt  DateTime?
  createdAt   DateTime  @default(now())

  campaign Campaign? @relation(fields: [campaignId], references: [id])
}

// ─── Legal ───────────────────────────────────────────────────────────
model LegalCase {
  id          String    @id @default(cuid())
  tenantId    String?
  caseNumber  String    @unique
  title       String
  type        String    @default("other")
  status      String    @default("open")
  plaintiff   String
  defendant   String
  court       String?
  lawyerId    String
  clientId    String?
  nextHearing DateTime?
  description String?   @db.Text
  actions     Json      @default("[]")
  documents   Json      @default("[]")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  client   Client?        @relation(fields: [clientId], references: [id])
  lawyer   User           @relation("CaseLawyer", fields: [lawyerId], references: [id])
  hearings CourtHearing[]
}

model LegalContract {
  id          String    @id @default(cuid())
  tenantId    String?
  title       String
  type        String    @default("service")
  parties     Json      @default("[]")
  startDate   DateTime
  endDate     DateTime?
  status      String    @default("draft")
  fileUrl     String?
  notes       String?   @db.Text
  createdById String
  createdAt   DateTime  @default(now())

  createdBy User @relation("LegalContractCreator", fields: [createdById], references: [id])
}

// ─── Forms / Survey ──────────────────────────────────────────────────
model SurveyForm {
  id          String    @id @default(cuid())
  tenantId    String?
  title       String
  description String?   @db.Text
  type        String    @default("custom")
  questions   Json      @default("[]")
  status      String    @default("draft")
  createdById String
  createdAt   DateTime  @default(now())
  closedAt    DateTime?

  responses FormResponse[]
  createdBy User           @relation("FormCreator", fields: [createdById], references: [id])
}

model FormResponse {
  id           String   @id @default(cuid())
  tenantId     String?
  formId       String
  respondentId String?
  answers      Json     @default("{}")
  leadId       String?
  submittedAt  DateTime @default(now())

  form SurveyForm @relation(fields: [formId], references: [id], onDelete: Cascade)
}

// ─── Portal ───────────────────────────────────────────────────────────
model PortalUser {
  id               String    @id @default(cuid())
  clientId         String
  name             String
  phone            String?   @unique
  email            String?   @unique
  passwordHash     String?
  role             String    @default("viewer")
  isActive         Boolean   @default(true)
  lastLoginAt      DateTime?
  resetToken       String?   @unique
  resetTokenExpiry DateTime?
  signatureDataUrl String?   @db.LongText
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  client        Client               @relation(fields: [clientId], references: [id], onDelete: Cascade)
  tickets       PortalTicket[]
  messages      PortalMessage[]
  notifications PortalNotification[]
}

model PortalTicket {
  id                String    @id @default(cuid())
  clientId          String
  portalUserId      String
  title             String
  description       String    @db.Text
  priority          String    @default("medium")
  status            String    @default("open")
  category          String    @default("general")
  satisfactionScore Int?
  createdAt         DateTime  @default(now())
  resolvedAt        DateTime?

  portalUser PortalUser          @relation(fields: [portalUserId], references: [id])
  replies    PortalTicketReply[]
}

model PortalTicketReply {
  id          String   @id @default(cuid())
  ticketId    String
  authorId    String
  authorType  String
  authorName  String
  content     String   @db.Text
  attachments Json     @default("[]")
  isRead      Boolean  @default(false)
  createdAt   DateTime @default(now())

  ticket PortalTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
}

model PortalMessage {
  id           String   @id @default(cuid())
  clientId     String
  portalUserId String?
  crmUserId    String?
  authorType   String
  authorName   String
  content      String   @db.Text
  attachments  Json     @default("[]")
  isRead       Boolean  @default(false)
  createdAt    DateTime @default(now())

  portalUser PortalUser? @relation(fields: [portalUserId], references: [id])
  crmUser    User?       @relation("CRMUserMessage", fields: [crmUserId], references: [id])
}

model PortalNotification {
  id           String   @id @default(cuid())
  portalUserId String
  type         String
  title        String
  body         String
  entityId     String?
  entityType   String?
  isRead       Boolean  @default(false)
  createdAt    DateTime @default(now())

  portalUser PortalUser @relation(fields: [portalUserId], references: [id], onDelete: Cascade)
}

model PortalPayment {
  id           String    @id @default(cuid())
  clientId     String
  invoiceId    String
  amount       Int
  method       String    @default("zarinpal")
  status       String    @default("pending")
  trackingCode String?
  authority    String?
  paidAt       DateTime?
  createdAt    DateTime  @default(now())
}

// ─── Team Messages (چت داخلی تیم) ────────────────────────────────────
model TeamConversation {
  id             String   @id @default(cuid())
  tenantId       String?
  participantIds Json     @default("[]")
  isGroup        Boolean  @default(false)
  groupName      String?
  isPinned       Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  messages TeamMessage[]
}

model TeamMessage {
  id             String   @id @default(cuid())
  conversationId String
  senderId       String
  content        String   @db.Text
  type           String   @default("text")
  readBy         Json     @default("[]")
  createdAt      DateTime @default(now())

  conversation TeamConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
}

// ─── Company Settings ─────────────────────────────────────────────────
model CompanySettings {
  id                 String  @id @default("default")
  name               String  @default("پرسی‌کور")
  legalName          String?
  taxId              String?
  registrationNumber String?
  address            String?
  phone              String?
  email              String?
  website            String?
  logoUrl            String?
  invoiceFooter      String? @db.Text
  invoiceColor       String  @default("#8B5CF6")
  timezone           String  @default("Asia/Tehran")
  currency           String  @default("IRR")
  primaryColor       String?
