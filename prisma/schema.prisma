}

// ─── Blog ─────────────────────────────────────────────────────────────
model BlogPost {
  id                String    @id @default(cuid())
  title             String
  slug              String    @unique
  excerpt           String?   @db.Text
  content           String    @db.LongText
  mdxContent        String?   @db.LongText
  contentType       String    @default("rich")
  coverImage        String?
  authorId          String
  categoryId        String?
  status            String    @default("draft")
  featured          Boolean   @default(false)
  publishedAt       DateTime?
  scheduledAt       DateTime?
  readingTime       Int       @default(0)
  views             Int       @default(0)
  // SEO پایه
  seoTitle          String?
  seoDesc           String?   @db.Text
  seoKeywords       String?
  focusKeyword      String?
  canonicalUrl      String?
  // Robots
  noIndex           Boolean   @default(false)
  noFollow          Boolean   @default(false)
  // Open Graph
  ogTitle           String?
  ogDesc            String?   @db.Text
  ogImage           String?
  ogType            String    @default("article")
  // Twitter Card
  twitterTitle      String?
  twitterDesc       String?   @db.Text
  twitterImage      String?
  twitterCard       String    @default("summary_large_image")
  // Schema
  schemaType        String    @default("BlogPosting")
  // Sitemap
  sitemapPriority   Float     @default(0.7)
  sitemapChangeFreq String    @default("weekly")

  tags      Json     @default("[]")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  author   User          @relation("BlogAuthor", fields: [authorId], references: [id])
  category BlogCategory? @relation(fields: [categoryId], references: [id])
  comments BlogComment[]

  @@index([status, publishedAt])
  @@index([slug])
}

model BlogCategory {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?  @db.Text
  color       String   @default("#8B5CF6")
  order       Int      @default(0)
  createdAt   DateTime @default(now())

  posts BlogPost[]
}

model BlogComment {
  id          String   @id @default(cuid())
  postId      String
  authorName  String
  authorEmail String
  content     String   @db.Text
  approved    Boolean  @default(false)
  createdAt   DateTime @default(now())

  post BlogPost @relation(fields: [postId], references: [id], onDelete: Cascade)
}

// ─── Site Settings ────────────────────────────────────────────────────
model SiteSettings {
  id               String   @id @default("main")
  siteName         String   @default("Persicore")
  siteTagline      String?
  siteDesc         String?  @db.Text
  logoUrl          String?
  faviconUrl       String?
  seoKeywords      String?
  googleAnalytics  String?
  twitter          String?
  instagram        String?
  linkedin         String?
  github           String?
  blogPostsPerPage Int      @default(9)
  blogShowAuthor   Boolean  @default(true)
  navItems         Json     @default("[]")
  footerLinks      Json     @default("[]")
  updatedAt        DateTime @default(now()) @updatedAt
}

// ─── Resume ───────────────────────────────────────────────────────────
model Resume {
  id          String  @id @default(cuid())
  slug        String  @unique
  isPublished Boolean @default(false)
  theme       String  @default("dark")
  accentColor String  @default("#8B5CF6")
  lang        String  @default("bilingual")

  // اطلاعات شخصی
  fullName   String
  fullNameFa String?
  title      String
  titleFa    String?
  bio        String? @db.Text
  bioFa      String? @db.Text
  avatar     String?
  coverImage String?
  location   String?
  locationFa String?
  email      String?
  phone      String?
  website    String?
  // شبکه اجتماعی
  linkedin   String?
  github     String?
  twitter    String?
  instagram  String?
  behance    String?
  dribbble   String?
  telegram   String?
  youtube    String?

  // بخش‌های رزومه
  experience     Json @default("[]")
  education      Json @default("[]")
  skills         Json @default("[]")
  projects       Json @default("[]")
  certifications Json @default("[]")
  awards         Json @default("[]")
  publications   Json @default("[]")
  languages      Json @default("[]")
  volunteering   Json @default("[]")
  references     Json @default("[]")
  customSections Json @default("[]")

  // SEO
  seoTitle String?
  seoDesc  String? @db.Text
  ogImage  String?

  // ترتیب بخش‌ها
  sectionOrder Json @default("[]")

  views     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([slug])
  @@index([isPublished])
}

// ─── Proposal ─────────────────────────────────────────────────────────
model Proposal {
  id          String  @id @default(cuid())
  slug        String  @unique
  isPublished Boolean @default(false)
  status      String  @default("draft") // draft | sent | viewed | accepted | rejected

  // اطلاعات مشتری
  clientName    String
  clientCompany String?
  clientEmail   String?
  clientPhone   String?

  // برندینگ
  primaryColor   String  @default("#8B5CF6")
  secondaryColor String  @default("#EC4899")
  darkMode       Boolean @default(true)
  agencyName     String  @default("Persicore")
  agencyLogo     String?
  coverImage     String?

  // معرفی پروژه
  projectTitle     String
  projectSubtitle  String?
  projectType      String  @default("website") // website | app | crm | ecommerce | other
  projectSummary   String? @db.Text
  problemStatement String? @db.Text
  ourSolution      String? @db.Text
  goals            Json    @default("[]") // string[]

  // اسکوپ کار
  deliverables Json @default("[]")
  // [{ id, title, description, icon, category }]

  // مراحل اجرا
  phases Json @default("[]")
  // [{ id, title, description, duration, tasks: string[] }]

  // پکیج‌های قیمتی
  currency String @default("تومان")
  packages Json   @default("[]")
  // [{ id, name, price, priceNote, description, features: string[], highlighted, color }]

  // پورتفولیو
  portfolioItems Json @default("[]")
  // [{ id, title, description, url, image, tags: string[] }]

  // مزایا
  advantages Json @default("[]")
  // [{ id, title, description, icon }]

  // تیم
  team Json @default("[]")
  // [{ id, name, role, avatar, bio }]

  // نظرات مشتریان
  testimonials Json @default("[]")
  // [{ id, name, company, role, text, avatar, rating }]

  // سوالات متداول
  faqs Json @default("[]")
  // [{ id, question, answer }]

  // CTA / تماس
  ctaTitle       String?
  ctaText        String? @db.Text
  ctaButtonText  String?
  contactEmail   String?
  contactPhone   String?
  contactAddress String?

  // شرایط
  validUntil DateTime?
  terms      String?   @db.Text
  notes      String?   @db.Text

  // SEO
  seoTitle String?
  seoDesc  String? @db.Text

  // روش کار
  process Json @default("[]")
  // [{ id, step, title, description, icon, duration }]

  // آمار شرکت
  stats Json @default("[]")
  // [{ id, value, label, icon }]

  // ترتیب بخش‌ها
  sectionOrder Json @default("[]")

  views    Int       @default(0)
  viewedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([slug])
  @@index([status])
}

