  title        String
  type         String   @default("other")
  fileUrl      String
  version      Int      @default(1)
  notes        String?
  uploadedById String
  createdAt    DateTime @default(now())

  uploadedBy User @relation("LegalDocUploader", fields: [uploadedById], references: [id])

  @@index([caseId])
