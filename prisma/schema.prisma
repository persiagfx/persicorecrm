// ═══════════════════════════════════════════════════════════════════
// ─── Industry Type ──────────────────────────────────────────────────
// ═══════════════════════════════════════════════════════════════════

enum IndustryType {
  GENERAL
  RESTAURANT
  IT
  MANUFACTURING
  TRADING
  SERVICE
  EDUCATION
  ECOMMERCE
}

// --- Tenant (SaaS Multi-tenancy) --------------------------------------
model Tenant {
  id           String       @id @default(cuid())
  name         String
  slug         String       @unique
  industry     String?
  industryType IndustryType @default(GENERAL)
  logoUrl      String?
  plan        String    @default("trial") // trial | starter | pro | enterprise
  status      String    @default("active") // active | suspended | cancelled
  trialEndsAt DateTime?
  maxUsers    Int       @default(3)
  maxClients  Int       @default(50)
  phone       String?
  address     String?
  ownerEmail  String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  users    User[]
  payments TenantPayment[]
}

model TenantPayment {
  id        String    @id @default(cuid())
  tenantId  String
  amount    Int
  plan      String
  months    Int       @default(1)
  status    String    @default("pending") // pending | paid | failed | refunded
  ref       String?
  note      String?
  paidAt    DateTime?
  createdAt DateTime  @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

// ─── Plan Configuration ───────────────────────────────────────────────
model PlanConfig {
  id           String   @id @default(cuid())
  key          String   @unique // trial | starter | pro | enterprise
  name         String
  nameFa       String
  monthlyPrice Int      @default(0)
  yearlyPrice  Int      @default(0)
  maxUsers     Int      @default(3)
  maxClients   Int      @default(50)
  maxStorageGb Int      @default(1)
  features     Json     @default("[]")
  isActive     Boolean  @default(true)
  order        Int      @default(0)
  color        String   @default("#8B5CF6")
  badge        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// ─── SaaS Support ────────────────────────────────────────────────────
model SupportRequest {
  id         String    @id @default(cuid())
  tenantId   String?
  userId     String?
  userEmail  String
  userName   String
  subject    String
  message    String    @db.Text
  category   String    @default("general") // general | billing | technical | feature
  priority   String    @default("medium") // low | medium | high | critical
  status     String    @default("open") // open | in_progress | waiting | resolved | closed
  adminNote  String?   @db.Text
  resolvedAt DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  replies SupportReply[]
}

model SupportReply {
  id         String   @id @default(cuid())
  requestId  String
  authorType String   @default("admin") // admin | user
  authorName String
  content    String   @db.Text
  createdAt  DateTime @default(now())

  request SupportRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
}

// ─── System Announcements ─────────────────────────────────────────────
model SystemAnnouncement {
  id          String    @id @default(cuid())
  title       String
  message     String    @db.Text
  type        String    @default("info") // info | warning | success | error
  targetPlans Json      @default("[]") // [] = all plans
  isActive    Boolean   @default(true)
  expiresAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

// ─── Coupons ──────────────────────────────────────────────────────────
model Coupon {
  id              String    @id @default(cuid())
  code            String    @unique
  description     String?
  discountType    String    @default("percent") // percent | fixed
  discountValue   Int
  maxUses         Int?
  usedCount       Int       @default(0)
  minAmount       Int?
  applicablePlans Json      @default("[]")
  isActive        Boolean   @default(true)
  expiresAt       DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  uses CouponUse[]
}

model CouponUse {
  id       String   @id @default(cuid())
  couponId String
  tenantId String
  amount   Int
  usedAt   DateTime @default(now())

  coupon Coupon @relation(fields: [couponId], references: [id])
}

// ─── Session Management ───────────────────────────────────────────────
model UserSession {
  id           String   @id @default(cuid())
  userId       String
  token        String   @db.Text
  tokenHash    String   @unique @db.VarChar(100)
  deviceInfo   String?
  ipAddress    String?
  userAgent    String?  @db.Text
  lastActiveAt DateTime @default(now())
  expiresAt    DateTime
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ─── Push Notifications ───────────────────────────────────────────────
model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  endpoint  String   @db.Text
  p256dh    String   @db.Text
  auth      String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ─── Webhooks ─────────────────────────────────────────────────────────
model Webhook {
  id        String   @id @default(cuid())
  tenantId  String?
  name      String
  url       String   @db.Text
  events    Json     @default("[]")
  secret    String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  deliveries WebhookDelivery[]
}

model WebhookDelivery {
  id          String    @id @default(cuid())
  webhookId   String
  event       String
  payload     Json
  statusCode  Int?
  response    String?   @db.Text
  attempts    Int       @default(0)
  deliveredAt DateTime?
  createdAt   DateTime  @default(now())

  webhook Webhook @relation(fields: [webhookId], references: [id], onDelete: Cascade)

  @@index([webhookId])
}

// ─── Automation Rules ─────────────────────────────────────────────────
model AutomationRule {
  id          String    @id @default(cuid())
  tenantId    String?
  name        String
  description String?   @db.Text
  trigger     Json
  actions     Json      @default("[]")
  isActive    Boolean   @default(true)
  runCount    Int       @default(0)
  lastRunAt   DateTime?
  createdById String
  createdAt   DateTime  @default(now())

  createdBy User @relation("AutomationCreator", fields: [createdById], references: [id])
}

// ─── Sales Funnel ─────────────────────────────────────────────────────
model SalesFunnel {
  id          String   @id @default(cuid())
  tenantId    String?
  name        String
  stages      Json     @default("[]")
  isDefault   Boolean  @default(false)
  createdById String
  createdAt   DateTime @default(now())

  createdBy User @relation("FunnelCreator", fields: [createdById], references: [id])
}

// ─── Customer Journey Map ─────────────────────────────────────────────
model CustomerJourney {
  id          String   @id @default(cuid())
  tenantId    String?
  name        String
  description String?  @db.Text
  persona     String?
  stages      Json     @default("[]")
  createdById String
  createdAt   DateTime @default(now())

  createdBy User @relation("JourneyCreator", fields: [createdById], references: [id])
}

// ─── Custom Report Builder ────────────────────────────────────────────
model SavedReport {
  id          String   @id @default(cuid())
  tenantId    String?
  name        String
  description String?
  config      Json
  isShared    Boolean  @default(false)
  createdById String
  createdAt   DateTime @default(now())

  createdBy User @relation("ReportCreator", fields: [createdById], references: [id])
}

// ─── Onboarding ───────────────────────────────────────────────────────
model OnboardingProgress {
  id        String   @id @default(cuid())
  tenantId  String   @unique
  steps     Json     @default("{}")
  completed Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── OTP Codes ───────────────────────────────────────────────────────
model OtpCode {
  id        String    @id @default(cuid())
  phone     String
  code      String
  purpose   String    @default("login") // login | register
  expiresAt DateTime
  usedAt    DateTime?
  attempts  Int       @default(0)
  createdAt DateTime  @default(now())

  @@index([phone, purpose])
  @@index([expiresAt])
}

// ─── Rate Limit (sliding window) ─────────────────────────────────────
model RateLimitEntry {
  id        String   @id @default(cuid())
  key       String   @unique
  count     Int      @default(0)
  resetAt   DateTime
  createdAt DateTime @default(now())

  @@index([key])
  @@index([resetAt])
}

// ═══════════════════════════════════════════════════════════════════
// ─── Content Generation Product ─────────────────────────────────────
// ═══════════════════════════════════════════════════════════════════

enum ContentPlan {
  FREE
  PRO
  PLUS
}

model ContentUser {
  id            String      @id @default(cuid())
  name          String
  email         String?     @unique
  phone         String?     @unique
  passwordHash  String?
  plan          ContentPlan @default(FREE)
  usedThisMonth Int         @default(0)
  monthResetAt  DateTime    @default(now())
  isActive      Boolean     @default(true)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  subscription  ContentSubscription?
  generations   ContentGeneration[]
}

model ContentSubscription {
  id            String      @id @default(cuid())
  userId        String      @unique
  plan          ContentPlan
  status        String      @default("active")
  expiresAt     DateTime
  zarinpalRefId String?
  authority     String?
  amount        Int
  createdAt     DateTime    @default(now())

  user ContentUser @relation(fields: [userId], references: [id])
}

model ContentGeneration {
  id            String   @id @default(cuid())
  contentUserId String?
  crmUserId     String?
  platform      String
  language      String   @default("fa")
  topic         String
  subtopics     Json     @default("[]")
  tone          String
  contentType   String
  keyword       String?
  textOutput    String   @db.LongText
  editedText    String?  @db.LongText
  imageUrl      String?
  seoScore      Int?
  metadata      Json     @default("{}")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  contentUser ContentUser? @relation(fields: [contentUserId], references: [id])

  @@index([contentUserId, createdAt(sort: Desc)])
  @@index([crmUserId, createdAt(sort: Desc)])
}

model ContentSettings {
  id            String  @id @default("global")
  freePlanLimit Int     @default(5)
  proPlanLimit  Int     @default(20)
  plusPlanLimit Int     @default(50)
  proPlanPrice  Int     @default(0)
  plusPlanPrice Int     @default(0)
  apiKey        String  @default("")
  textModel     String  @default("gpt-5.4")
  imageModel    String  @default("gemini-3-pro-image-preview")
  isActive      Boolean @default(true)
  updatedAt     DateTime @updatedAt
}

// ═══════════════════════════════════════════════════════════════════
// ─── Agent Chatbot Builder Product ──────────────────────────────────
// ═══════════════════════════════════════════════════════════════════

enum AgentPlan {
  FREE
  STARTER
  PRO
  ENTERPRISE
}

enum AgentStatus {
  DRAFT
  ACTIVE
  PAUSED
  DELETED
}

enum KnowledgeType {
  TEXT
  FILE
  URL
}

enum KnowledgeStatus {
  PROCESSING
  READY
  FAILED
}

// ─── Agent User (separate auth, like ContentUser) ─────────────────
model AgentUser {
  id           String    @id @default(cuid())
  name         String
  email        String?   @unique
  phone        String?   @unique
  passwordHash String?
  plan         AgentPlan @default(FREE)
  isActive     Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  subscription AgentSubscription?
  agents       Agent[]
}

model AgentSubscription {
  id            String    @id @default(cuid())
  userId        String    @unique
  plan          AgentPlan
  status        String    @default("active")
  expiresAt     DateTime
  zarinpalRefId String?
  authority     String?
  amount        Int
  createdAt     DateTime  @default(now())

  user AgentUser @relation(fields: [userId], references: [id])
}

// ─── Agent (the chatbot) ──────────────────────────────────────────
model Agent {
  id             String      @id @default(cuid())
  userId         String
  name           String
  slug           String      @unique
  businessType   String
  status         AgentStatus @default(DRAFT)
  welcomeMessage String?     @db.Text
  fallbackMessage String?    @db.Text
  tone           String      @default("friendly")
  languages      Json        @default("[\"fa\"]")
  systemPrompt   String?     @db.LongText
  totalMessages  Int         @default(0)
  totalConversations Int     @default(0)
  totalLeads     Int         @default(0)
  lastActiveAt   DateTime?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  user           AgentUser          @relation(fields: [userId], references: [id])
  knowledge      AgentKnowledge[]
  conversations  AgentConversation[]
  customization  AgentCustomization?

  @@index([userId])
  @@index([slug])
}

// ─── Knowledge Base ───────────────────────────────────────────────
model AgentKnowledge {
  id        String          @id @default(cuid())
  agentId   String
  type      KnowledgeType   @default(TEXT)
  title     String
  content   String          @db.LongText
  sourceUrl String?
  fileUrl   String?
  status    KnowledgeStatus @default(READY)
  tokens    Int             @default(0)
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  agent Agent @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@index([agentId])
}

// ─── Customization ────────────────────────────────────────────────
model AgentCustomization {
  id             String  @id @default(cuid())
  agentId        String  @unique
  primaryColor   String  @default("#5b6cff")
  avatarType     String  @default("initials")
  avatarUrl      String?
  avatarEmoji    String?
  position       String  @default("bottom-left")
  widgetTitle    String?
  inputPlaceholder String?
  showBranding   Boolean @default(true)
  darkMode       Boolean @default(false)
  borderRadius   Int     @default(16)

  agent Agent @relation(fields: [agentId], references: [id], onDelete: Cascade)
}

// ─── Conversations ────────────────────────────────────────────────
model AgentConversation {
  id             String    @id @default(cuid())
  agentId        String
  sessionId      String
  visitorName    String?
  visitorEmail   String?
  visitorPhone   String?
  messageCount   Int       @default(0)
  leadCreated    Boolean   @default(false)
  crmLeadId      String?
  startedAt      DateTime  @default(now())
  lastMessageAt  DateTime  @default(now())
  isResolved     Boolean   @default(false)
  metadata       Json?

  agent    Agent          @relation(fields: [agentId], references: [id], onDelete: Cascade)
  messages AgentMessage[]

  @@index([agentId])
  @@index([agentId, startedAt(sort: Desc)])
  @@index([sessionId])
}

// ─── Messages ─────────────────────────────────────────────────────
model AgentMessage {
  id             String   @id @default(cuid())
  conversationId String
  role           String   @default("user")
  content        String   @db.Text
  tokensUsed     Int      @default(0)
  createdAt      DateTime @default(now())

  conversation AgentConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
}

// ─── Business Types (admin-configurable) ─────────────────────────
model AgentBusinessType {
  id          String   @id @default(cuid())
  key         String   @unique
  nameFa      String
  icon        String   @default("🏢")
  description String?
  questions   Json     @default("[]")
  isActive    Boolean  @default(true)
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ─── Global Settings ──────────────────────────────────────────────
model AgentSettings {
  id               String  @id @default("global")
  freePlanAgents   Int     @default(1)
  starterPlanAgents Int    @default(3)
  proPlanAgents    Int     @default(10)
  enterprisePlanAgents Int @default(50)
  freePlanMessages Int     @default(100)
  starterPlanMessages Int  @default(1000)
  proPlanMessages  Int     @default(5000)
  enterprisePlanMessages Int @default(50000)
  starterPlanPrice Int     @default(0)
  proPlanPrice     Int     @default(0)
  enterprisePlanPrice Int  @default(0)
  apiKey           String  @default("")
  textModel        String  @default("gpt-5.4")
  isActive         Boolean @default(true)
  globalBlacklist  Json    @default("[]")
  updatedAt        DateTime @updatedAt
}

// ═══════════════════════════════════════════════════════════════════
// ─── SHARED: Inventory Management (انبار و موجودی) ───────────────────
// ═══════════════════════════════════════════════════════════════════

model InventoryCategory {
  id        String   @id @default(cuid())
  tenantId  String?
  name      String
  color     String   @default("#8B5CF6")
  icon      String?
  createdAt DateTime @default(now())

  items InventoryItem[]

  @@index([tenantId])
}

model InventoryItem {
  id           String   @id @default(cuid())
  tenantId     String?
  categoryId   String?
  name         String
  sku          String?
  barcode      String?
  unit         String   @default("عدد")
  currentStock Float    @default(0)
  minStock     Float    @default(0)
  maxStock     Float?
  costPrice    Int      @default(0)
  sellPrice    Int      @default(0)
  locationId   String?
  supplierId   String?
  description  String?  @db.Text
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  category  InventoryCategory? @relation(fields: [categoryId], references: [id])
  location  InventoryLocation? @relation(fields: [locationId], references: [id])
  supplier  Supplier?          @relation(fields: [supplierId], references: [id])
  movements InventoryMovement[]

  @@index([tenantId])
  @@index([tenantId, sku])
}

model InventoryLocation {
  id        String   @id @default(cuid())
  tenantId  String?
  name      String
  code      String?
  notes     String?
  createdAt DateTime @default(now())

  items InventoryItem[]

  @@index([tenantId])
}

model InventoryMovement {
  id        String   @id @default(cuid())
  tenantId  String?
  itemId    String
  type      String   @default("in") // in | out | adjust | transfer
  quantity  Float
  before    Float    @default(0)
  after     Float    @default(0)
  reason    String?
  reference String?
  userId    String?
  createdAt DateTime @default(now())

  item InventoryItem @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@index([itemId])
  @@index([tenantId, createdAt(sort: Desc)])
}

model StockCount {
  id          String   @id @default(cuid())
  tenantId    String?
  name        String
  date        DateTime @default(now())
  status      String   @default("draft") // draft | in_progress | completed
  items       Json     @default("[]")
  notes       String?  @db.Text
  conductedBy String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([tenantId])
  @@index([tenantId, date])
}

// ═══════════════════════════════════════════════════════════════════
// ─── SHARED: Supplier & Purchase Orders (تامین‌کنندگان) ──────────────
// ═══════════════════════════════════════════════════════════════════

model Supplier {
  id           String   @id @default(cuid())
  tenantId     String?
  name         String
  contactName  String?
  phone        String?
  email        String?
  address      String?  @db.Text
  taxId        String?
  bankAccount  String?
  paymentTerms String?
  rating       Int      @default(0)
  notes        String?  @db.Text
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  inventoryItems InventoryItem[]
  purchaseOrders PurchaseOrder[]

  @@index([tenantId])
}

model PurchaseOrder {
  id          String    @id @default(cuid())
  tenantId    String?
  number      String    @unique
  supplierId  String
  status      String    @default("draft") // draft | sent | confirmed | received | cancelled
  orderDate   DateTime  @default(now())
  expectedAt  DateTime?
  receivedAt  DateTime?
  subtotal    Int       @default(0)
  taxAmount   Int       @default(0)
  total       Int       @default(0)
  notes       String?   @db.Text
  createdById String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  supplier Supplier           @relation(fields: [supplierId], references: [id])
  items    PurchaseOrderItem[]

  @@index([tenantId])
  @@index([tenantId, status])
}

model PurchaseOrderItem {
  id          String @id @default(cuid())
  orderId     String
  itemName    String
  inventoryItemId String?
  quantity    Float
  unitPrice   Int
  totalPrice  Int
  receivedQty Float  @default(0)

  order PurchaseOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

// ═══════════════════════════════════════════════════════════════════
// ─── SHARED: Returns (مرجوعی کالا) ────────────────────────────────────
// ═══════════════════════════════════════════════════════════════════

model ReturnRequest {
  id          String   @id @default(cuid())
  tenantId    String?
  type        String   @default("customer") // customer | supplier
  entityId    String?
  reason      String
  status      String   @default("pending") // pending | approved | rejected | refunded
  totalValue  Int      @default(0)
  notes       String?  @db.Text
  createdById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  items ReturnRequestItem[]

  @@index([tenantId])
}

model ReturnRequestItem {
  id         String @id @default(cuid())
  returnId   String
  itemName   String
  quantity   Float
  unitPrice  Int
  totalPrice Int

  returnRequest ReturnRequest @relation(fields: [returnId], references: [id], onDelete: Cascade)
}

// ═══════════════════════════════════════════════════════════════════
// ─── RESTAURANT: کافه / رستوران ───────────────────────────────────────
// ═══════════════════════════════════════════════════════════════════

model RestMenuCategory {
  id        String   @id @default(cuid())
  tenantId  String?
  name      String
  icon      String?
  order     Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  items RestMenuItem[]

  @@index([tenantId])
}

model RestMenuItem {
  id          String   @id @default(cuid())
  tenantId    String?
  categoryId  String
  name        String
  description String?  @db.Text
  price       Int      @default(0)
  oldPrice    Int?
  imageUrl    String?
  isAvailable Boolean  @default(true)
  isSpecial   Boolean  @default(false)
  prepTime    Int?
  calories    Int?
  tags        Json     @default("[]")
  allergens   Json     @default("[]")
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  category   RestMenuCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  orderItems RestOrderItem[]

  @@index([tenantId])
}

model RestTable {
  id        String   @id @default(cuid())
  tenantId  String?
  number    Int
  name      String?
  capacity  Int      @default(4)
  floor     String?
  status    String   @default("available") // available | occupied | reserved | cleaning
  isActive  Boolean  @default(true)
  qrCode    String?
  createdAt DateTime @default(now())

  reservations RestReservation[]
  orders       RestOrder[]

  @@index([tenantId])
}

model RestReservation {
  id         String   @id @default(cuid())
  tenantId   String?
  tableId    String?
  guestName  String
  guestPhone String
  guestCount Int      @default(1)
  date       DateTime
  duration   Int      @default(90)
  status     String   @default("confirmed") // confirmed | cancelled | completed | no_show
  notes      String?
  createdAt  DateTime @default(now())

  table RestTable? @relation(fields: [tableId], references: [id])

  @@index([tenantId])
  @@index([tenantId, date])
}

model RestOrder {
  id          String   @id @default(cuid())
  tenantId    String?
  tableId     String?
  orderNumber String   @unique
  type        String   @default("dine_in") // dine_in | takeaway | delivery
  status      String   @default("new") // new | preparing | ready | served | paid | cancelled
  subtotal    Int      @default(0)
  taxAmount   Int      @default(0)
  discount    Int      @default(0)
  total       Int      @default(0)
  paidAmount  Int      @default(0)
  payMethod   String?
  notes       String?
  staffId     String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  table RestTable?      @relation(fields: [tableId], references: [id])
  items RestOrderItem[]

  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, createdAt(sort: Desc)])
}

model RestOrderItem {
  id         String  @id @default(cuid())
  orderId    String
  menuItemId String?
  name       String
  quantity   Int     @default(1)
  unitPrice  Int
  totalPrice Int
  notes      String?
  status     String  @default("pending") // pending | preparing | ready | served | cancelled

  order    RestOrder     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  menuItem RestMenuItem? @relation(fields: [menuItemId], references: [id])
}

model RestShift {
  id         String   @id @default(cuid())
  tenantId   String?
  name       String
  date       DateTime
  startTime  String
  endTime    String
  staffIds   Json     @default("[]")
  notes      String?
  status     String   @default("scheduled") // scheduled | active | ended
  totalSales Int      @default(0)
  createdAt  DateTime @default(now())

  @@index([tenantId])
  @@index([tenantId, date])
}

// ═══════════════════════════════════════════════════════════════════
// ─── IT: فناوری اطلاعات ───────────────────────────────────────────────
// ═══════════════════════════════════════════════════════════════════

model Sprint {
  id        String   @id @default(cuid())
  tenantId  String?
  projectId String?
  name      String
  goal      String?  @db.Text
  startDate DateTime
  endDate   DateTime
  status    String   @default("planned") // planned | active | completed | cancelled
  velocity  Int?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tasks SprintTask[]

  @@index([tenantId])
  @@index([tenantId, status])
}

model SprintTask {
  id          String   @id @default(cuid())
  sprintId    String
  title       String
  description String?  @db.Text
  type        String   @default("story") // story | bug | task | epic
  status      String   @default("todo") // todo | in_progress | review | done
  priority    String   @default("medium")
  points      Int?
  assigneeId  String?
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  sprint Sprint @relation(fields: [sprintId], references: [id], onDelete: Cascade)

  @@index([sprintId])
}

model BugReport {
  id          String    @id @default(cuid())
  tenantId    String?
  projectId   String?
  title       String
  description String    @db.LongText
  steps       String?   @db.Text
  expected    String?   @db.Text
  actual      String?   @db.Text
  severity    String    @default("medium") // critical | high | medium | low
  status      String    @default("open") // open | confirmed | in_progress | resolved | closed | duplicate
  assigneeId  String?
  reporterId  String?
  environment String?
  version     String?
  attachments Json      @default("[]")
  resolvedAt  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  comments BugComment[]

  @@index([tenantId])
  @@index([tenantId, status])
}

model BugComment {
  id        String   @id @default(cuid())
  bugId     String
  authorId  String?
  content   String   @db.Text
  createdAt DateTime @default(now())

  bug BugReport @relation(fields: [bugId], references: [id], onDelete: Cascade)
}

model ProductRoadmap {
  id          String   @id @default(cuid())
  tenantId    String?
  name        String
  description String?  @db.Text
  isDefault   Boolean  @default(false)
  createdAt   DateTime @default(now())

  features RoadmapFeature[]

  @@index([tenantId])
}

model RoadmapFeature {
  id          String    @id @default(cuid())
  roadmapId   String
  title       String
  description String?   @db.Text
  status      String    @default("planned") // planned | in_progress | completed | cancelled
  priority    String    @default("medium")
  quarter     String?
  estimatedAt DateTime?
  completedAt DateTime?
  tags        Json      @default("[]")
  order       Int       @default(0)
  createdAt   DateTime  @default(now())

  roadmap ProductRoadmap @relation(fields: [roadmapId], references: [id], onDelete: Cascade)
}

model SoftwareLicense {
  id          String    @id @default(cuid())
  tenantId    String?
  name        String
  vendor      String?
  licenseKey  String?
  type        String    @default("subscription") // perpetual | subscription | concurrent
  seats       Int?
  usedSeats   Int       @default(0)
  purchasedAt DateTime?
  expiresAt   DateTime?
  cost        Int       @default(0)
  notes       String?   @db.Text
  status      String    @default("active") // active | expired | cancelled
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([tenantId])
}

// ═══════════════════════════════════════════════════════════════════
// ─── MANUFACTURING: تولیدی / کارخانه ─────────────────────────────────
// ═══════════════════════════════════════════════════════════════════

model ProductionLine {
  id        String   @id @default(cuid())
  tenantId  String?
  name      String
  code      String?
  capacity  Int?
  unit      String   @default("عدد/روز")
  isActive  Boolean  @default(true)
  notes     String?
  createdAt DateTime @default(now())

  orders ProductionOrder[]

  @@index([tenantId])
}

model ProductionOrder {
  id           String    @id @default(cuid())
  tenantId     String?
  number       String    @unique
  lineId       String?
  productName  String
  quantity     Float
  unit         String    @default("عدد")
  status       String    @default("planned") // planned | in_progress | paused | completed | cancelled
  priority     String    @default("normal")
  startDate    DateTime
  dueDate      DateTime
  completedAt  DateTime?
  completedQty Float     @default(0)
  rejectedQty  Float     @default(0)
  notes        String?   @db.Text
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  line     ProductionLine?  @relation(fields: [lineId], references: [id])
  bomItems BOMItem[]
  qcChecks QualityCheck[]

  @@index([tenantId])
  @@index([tenantId, status])
}

model BOMItem {
  id                String  @id @default(cuid())
  productionOrderId String?
  tenantId          String?
  productName       String
  materialName      String
  quantity          Float
  unit              String  @default("عدد")
  unitCost          Int     @default(0)
  inventoryItemId   String?
  notes             String?

  productionOrder ProductionOrder? @relation(fields: [productionOrderId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}

model QualityCheck {
  id                String    @id @default(cuid())
  tenantId          String?
  productionOrderId String?
  checkName         String
  inspector         String?
  status            String    @default("pending") // pending | passed | failed | conditional
  checkedAt         DateTime?
  parameters        Json      @default("[]")
  result            String?   @db.Text
  defectCount       Int       @default(0)
  createdAt         DateTime  @default(now())

  productionOrder ProductionOrder? @relation(fields: [productionOrderId], references: [id])

  @@index([tenantId])
}

model Equipment {
  id           String    @id @default(cuid())
  tenantId     String?
  name         String
  code         String?
  category     String    @default("machine")
  location     String?
  brand        String?
  model        String?
  serialNumber String?
  purchasedAt  DateTime?
  warrantyEnd  DateTime?
  status       String    @default("operational") // operational | maintenance | broken | retired
  notes        String?   @db.Text
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  maintenanceRecords MaintenanceRecord[]

  @@index([tenantId])
}

model MaintenanceRecord {
  id           String    @id @default(cuid())
  tenantId     String?
  equipmentId  String
  type         String    @default("preventive") // preventive | corrective | emergency
  description  String?   @db.Text
  technicianId String?
  startedAt    DateTime
  completedAt  DateTime?
  cost         Int       @default(0)
  status       String    @default("scheduled") // scheduled | in_progress | completed | cancelled
  nextDueAt    DateTime?
  createdAt    DateTime  @default(now())

  equipment Equipment @relation(fields: [equipmentId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([equipmentId])
}

model WasteRecord {
  id             String   @id @default(cuid())
  tenantId       String?
  date           DateTime
  productName    String
  quantity       Float
  unit           String   @default("عدد")
  reason         String?
  stage          String?
  cost           Int      @default(0)
  disposalMethod String?
  reportedById   String?
  createdAt      DateTime @default(now())

  @@index([tenantId])
  @@index([tenantId, date])
}

// ═══════════════════════════════════════════════════════════════════
// ─── TRADING: بازرگانی ────────────────────────────────────────────────
// ═══════════════════════════════════════════════════════════════════

model Shipment {
  id           String    @id @default(cuid())
  tenantId     String?
  number       String    @unique
  type         String    @default("outbound") // outbound | inbound
  origin       String?
  destination  String?
  carrierName  String?
  trackingCode String?
  status       String    @default("preparing") // preparing | shipped | in_transit | customs | delivered | returned
  weight       Float?
  volume       Float?
  shippedAt    DateTime?
  estimatedAt  DateTime?
  deliveredAt  DateTime?
  cost         Int       @default(0)
  invoiceId    String?
  notes        String?   @db.Text
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  items       ShipmentItem[]
  trackingLogs ShipmentTrackingLog[]

  @@index([tenantId])
  @@index([tenantId, status])
}

model ShipmentItem {
  id            String @id @default(cuid())
  shipmentId    String
  name          String
  quantity      Float
  unit          String @default("عدد")
  weight        Float?
  declaredValue Int?
  hsCode        String?

  shipment Shipment @relation(fields: [shipmentId], references: [id], onDelete: Cascade)
}

model ShipmentTrackingLog {
  id         String   @id @default(cuid())
  shipmentId String
  status     String
  location   String?
  notes      String?
  loggedAt   DateTime @default(now())

  shipment Shipment @relation(fields: [shipmentId], references: [id], onDelete: Cascade)

  @@index([shipmentId])
}

model TradeRecord {
  id            String    @id @default(cuid())
  tenantId      String?
  type          String    @default("import") // import | export
  country       String
  productName   String
  quantity      Float
  unit          String    @default("عدد")
  unitPrice     Int
  totalValue    Int
  currency      String    @default("USD")
  exchangeRate  Float?
  customsValue  Int?
  duties        Int       @default(0)
  clearanceDate DateTime?
  status        String    @default("in_progress") // in_progress | cleared | rejected
  documents     Json      @default("[]")
  notes         String?   @db.Text
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([tenantId])
  @@index([tenantId, type])
}

model PricingTier {
  id        String   @id @default(cuid())
  tenantId  String?
  name      String
  minQty    Float    @default(1)
  maxQty    Float?
  discount  Float    @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  rules PricingTierRule[]

  @@index([tenantId])
}

model PricingTierRule {
  id            String  @id @default(cuid())
  tierId        String
  itemName      String?
  inventoryItemId String?
  priceOverride Int?

  tier PricingTier @relation(fields: [tierId], references: [id], onDelete: Cascade)
}

// ═══════════════════════════════════════════════════════════════════
// ─── SERVICE: خدماتی ──────────────────────────────────────────────────
// ═══════════════════════════════════════════════════════════════════

model ServiceRequest {
  id           String    @id @default(cuid())
  tenantId     String?
  number       String    @unique
  clientId     String?
  title        String
  description  String    @db.Text
  category     String    @default("general")
  priority     String    @default("medium") // low | medium | high | urgent
  status       String    @default("new") // new | assigned | in_progress | pending_approval | completed | cancelled
  assigneeId   String?
  technicianId String?
  slaId        String?
  slaDeadline  DateTime?
  slaBreached  Boolean   @default(false)
  location     String?
  scheduledAt  DateTime?
  startedAt    DateTime?
  completedAt  DateTime?
  feedbackScore Int?
  cost         Int       @default(0)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  logs     ServiceRequestLog[]
  feedback ServiceFeedback?

  @@index([tenantId])
  @@index([tenantId, status])
}

model ServiceRequestLog {
  id        String   @id @default(cuid())
  requestId String
  type      String   @default("note") // note | status_change | assignment | location_update
  content   String   @db.Text
  authorId  String?
  createdAt DateTime @default(now())

  request ServiceRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)

  @@index([requestId])
}

model TechnicianSchedule {
  id           String   @id @default(cuid())
  tenantId     String?
  technicianId String
  date         DateTime
  startTime    String
  endTime      String
  requestId    String?
  status       String   @default("scheduled") // scheduled | in_progress | completed | cancelled
  notes        String?
  createdAt    DateTime @default(now())

  @@index([tenantId])
  @@index([technicianId, date])
}

model SLAPolicy {
  id               String   @id @default(cuid())
  tenantId         String?
  name             String
  priority         String   @default("medium")
  responseTimeHrs  Int      @default(4)
  resolutionTimeHrs Int     @default(24)
  isActive         Boolean  @default(true)
  createdAt        DateTime @default(now())

  @@index([tenantId])
}

model ServiceFeedback {
  id          String   @id @default(cuid())
  requestId   String   @unique
  score       Int
  comment     String?  @db.Text
  submittedAt DateTime @default(now())

  request ServiceRequest @relation(fields: [requestId], references: [id])
}

// ═══════════════════════════════════════════════════════════════════
// ─── EDUCATION: آموزشی ────────────────────────────────────────────────
// ═══════════════════════════════════════════════════════════════════

model EduCourse {
  id           String   @id @default(cuid())
  tenantId     String?
  title        String
  code         String?
  description  String?  @db.Text
  category     String?
  level        String   @default("beginner") // beginner | intermediate | advanced
  durationHrs  Float?
  price        Int      @default(0)
  maxStudents  Int?
  instructorId String?
  coverImage   String?
  status       String   @default("draft") // draft | published | archived
  isOnline     Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  lessons     EduLesson[]
  enrollments EduEnrollment[]
  schedules   EduClassSchedule[]
  exams       EduExam[]

  @@index([tenantId])
}

model EduLesson {
  id          String   @id @default(cuid())
  courseId    String
  title       String
  content     String?  @db.LongText
  type        String   @default("text") // video | text | quiz | file
  duration    Int?
  fileUrl     String?
  videoUrl    String?
  order       Int      @default(0)
  isPublished Boolean  @default(false)
  createdAt   DateTime @default(now())

  course EduCourse @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@index([courseId])
}

model EduStudent {
  id            String    @id @default(cuid())
  tenantId      String?
  name          String
  phone         String?
  email         String?
  birthDate     DateTime?
  nationalId    String?
  address       String?   @db.Text
  guardianName  String?
  guardianPhone String?
  status        String    @default("active") // active | inactive | graduated
  notes         String?   @db.Text
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  enrollments     EduEnrollment[]
  attendances     EduStudentAttendance[]
  examSubmissions EduExamSubmission[]
  certificates    EduCertificate[]

  @@index([tenantId])
}

model EduEnrollment {
  id          String    @id @default(cuid())
  tenantId    String?
  courseId    String
  studentId   String
  enrolledAt  DateTime  @default(now())
  completedAt DateTime?
  progress    Float     @default(0)
  status      String    @default("active") // active | completed | dropped | suspended
  paidAmount  Int       @default(0)
  discount    Int       @default(0)
  finalScore  Float?

  course  EduCourse  @relation(fields: [courseId], references: [id])
  student EduStudent @relation(fields: [studentId], references: [id])

  @@unique([courseId, studentId])
  @@index([tenantId])
}

model EduClassSchedule {
  id         String   @id @default(cuid())
  tenantId   String?
  courseId   String
  title      String?
  dayOfWeek  Int
  startTime  String
  endTime    String
  room       String?
  isOnline   Boolean  @default(false)
  meetingUrl String?
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())

  course   EduCourse         @relation(fields: [courseId], references: [id])
  sessions EduClassSession[]

  @@index([tenantId])
}

model EduClassSession {
  id         String    @id @default(cuid())
  scheduleId String
  date       DateTime
  status     String    @default("scheduled") // scheduled | held | cancelled
  topic      String?
  notes      String?
  startedAt  DateTime?
  endedAt    DateTime?
  createdAt  DateTime  @default(now())

  schedule    EduClassSchedule       @relation(fields: [scheduleId], references: [id])
  attendances EduStudentAttendance[]

  @@index([scheduleId])
}

model EduStudentAttendance {
  id        String   @id @default(cuid())
  sessionId String
  studentId String
  status    String   @default("present") // present | absent | late | excused
  notes     String?
  createdAt DateTime @default(now())

  session EduClassSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  student EduStudent      @relation(fields: [studentId], references: [id])

  @@unique([sessionId, studentId])
}

model EduExam {
  id          String    @id @default(cuid())
  tenantId    String?
  courseId    String?
  title       String
  description String?   @db.Text
  type        String    @default("quiz") // quiz | midterm | final | assignment
  duration    Int?
  totalPoints Int       @default(100)
  passScore   Int       @default(50)
  startAt     DateTime?
  endAt       DateTime?
  isPublished Boolean   @default(false)
  createdAt   DateTime  @default(now())

  course      EduCourse?          @relation(fields: [courseId], references: [id])
  questions   EduExamQuestion[]
  submissions EduExamSubmission[]

  @@index([tenantId])
}

model EduExamQuestion {
  id        String   @id @default(cuid())
  examId    String
  text      String   @db.Text
  type      String   @default("mcq") // mcq | true_false | short_answer | essay
  options   Json     @default("[]")
  answer    String?  @db.Text
  points    Int      @default(10)
  order     Int      @default(0)
  createdAt DateTime @default(now())

  exam EduExam @relation(fields: [examId], references: [id], onDelete: Cascade)
}

model EduExamSubmission {
  id          String    @id @default(cuid())
  examId      String
  studentId   String
  answers     Json      @default("{}")
  score       Float?
  isPassed    Boolean?
  submittedAt DateTime  @default(now())
  gradedAt    DateTime?
  feedback    String?   @db.Text

  exam    EduExam    @relation(fields: [examId], references: [id])
  student EduStudent @relation(fields: [studentId], references: [id])

  @@unique([examId, studentId])
}

model EduCertificate {
  id        String    @id @default(cuid())
  tenantId  String?
  studentId String
  courseId  String?
  title     String
  issuedAt  DateTime  @default(now())
  expiresAt DateTime?
  code      String    @unique
  fileUrl   String?
  notes     String?

  student EduStudent @relation(fields: [studentId], references: [id])

  @@index([tenantId])
}

// ═══════════════════════════════════════════════════════════════════
// ─── ECOMMERCE: فروشگاهی / آنلاین‌شاپ ─────────────────────────────────
// ═══════════════════════════════════════════════════════════════════

model EcomProductCategory {
  id        String   @id @default(cuid())
  tenantId  String?
  name      String
  slug      String
  parentId  String?
  imageUrl  String?
  order     Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  parent   EcomProductCategory?  @relation("EcomCategoryHierarchy", fields: [parentId], references: [id])
  children EcomProductCategory[] @relation("EcomCategoryHierarchy")
  products EcomProduct[]

  @@index([tenantId])
}

model EcomProduct {
  id          String   @id @default(cuid())
  tenantId    String?
  categoryId  String?
  name        String
  slug        String
  description String?  @db.LongText
  shortDesc   String?  @db.Text
  sku         String?
  barcode     String?
  basePrice   Int      @default(0)
  salePrice   Int?
  stock       Int      @default(0)
  minStock    Int      @default(0)
  weight      Float?
  tags        Json     @default("[]")
  images      Json     @default("[]")
  isPublished Boolean  @default(false)
  isFeatured  Boolean  @default(false)
  seoTitle    String?
  seoDesc     String?  @db.Text
  rating      Float    @default(0)
  reviewCount Int      @default(0)
  soldCount   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  category   EcomProductCategory?  @relation(fields: [categoryId], references: [id])
  variants   EcomProductVariant[]
  reviews    EcomProductReview[]
  orderItems EcomOrderItem[]

  @@index([tenantId])
  @@index([tenantId, isPublished])
}

model EcomProductVariant {
  id         String  @id @default(cuid())
  productId  String
  name       String
  sku        String?
  price      Int
  stock      Int     @default(0)
  attributes Json    @default("{}")
  imageUrl   String?
  isActive   Boolean @default(true)

  product EcomProduct @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
}

model EcomOrder {
  id            String    @id @default(cuid())
  tenantId      String?
  number        String    @unique
  customerId    String?
  customerName  String
  customerPhone String?
  customerEmail String?
  shippingAddr  String?   @db.Text
  status        String    @default("pending") // pending | confirmed | processing | shipped | delivered | cancelled | refunded
  paymentStatus String    @default("unpaid") // unpaid | paid | partially_paid | refunded
  paymentMethod String?
  subtotal      Int       @default(0)
  shippingFee   Int       @default(0)
  discount      Int       @default(0)
  taxAmount     Int       @default(0)
  total         Int       @default(0)
  paidAt        DateTime?
  shippedAt     DateTime?
  deliveredAt   DateTime?
  notes         String?   @db.Text
  discountCode  String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  items    EcomOrderItem[]
  delivery EcomDelivery?

  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, createdAt(sort: Desc)])
}

model EcomOrderItem {
  id         String  @id @default(cuid())
  orderId    String
  productId  String?
  variantId  String?
  name       String
  sku        String?
  quantity   Int     @default(1)
  unitPrice  Int
  totalPrice Int
  imageUrl   String?

  order   EcomOrder    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product EcomProduct? @relation(fields: [productId], references: [id])
}

model EcomDiscountCode {
  id            String    @id @default(cuid())
  tenantId      String?
  code          String    @unique
  description   String?
  type          String    @default("percent") // percent | fixed | free_shipping
  value         Int
  minOrderValue Int?
  maxUses       Int?
  usedCount     Int       @default(0)
  startAt       DateTime?
  endAt         DateTime?
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())

  uses EcomDiscountUse[]

  @@index([tenantId])
}

model EcomDiscountUse {
  id      String   @id @default(cuid())
  codeId  String
  orderId String?
  usedAt  DateTime @default(now())

  code EcomDiscountCode @relation(fields: [codeId], references: [id])
}

model EcomDelivery {
  id           String    @id @default(cuid())
  tenantId     String?
  orderId      String    @unique
  carrier      String?
  trackingCode String?
  status       String    @default("pending") // pending | picked_up | in_transit | out_for_delivery | delivered | failed
  estimatedAt  DateTime?
  deliveredAt  DateTime?
  createdAt    DateTime  @default(now())

  order EcomOrder         @relation(fields: [orderId], references: [id])
  logs  EcomDeliveryLog[]

  @@index([tenantId])
}

model EcomDeliveryLog {
  id         String   @id @default(cuid())
  deliveryId String
  status     String
  location   String?
  notes      String?
  loggedAt   DateTime @default(now())

  delivery EcomDelivery @relation(fields: [deliveryId], references: [id], onDelete: Cascade)
}

model EcomProductReview {
  id          String   @id @default(cuid())
  tenantId    String?
  productId   String
  authorName  String
  authorEmail String?
  rating      Int
  title       String?
  comment     String?  @db.Text
  isApproved  Boolean  @default(false)
  createdAt   DateTime @default(now())

  product EcomProduct @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@index([tenantId])
}

// ═══════════════════════════════════════════════════════════════════
// ─── HR: Shifts & Onboarding ─────────────────────────────────────
// ═══════════════════════════════════════════════════════════════════

model WorkShift {
  id        String   @id @default(cuid())
  tenantId  String?
  name      String
  startTime String
  endTime   String
  breakMins Int      @default(60)
  workDays  Json     @default("[1,2,3,4,5]")
  color     String   @default("#6366f1")
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  assignments ShiftAssignment[]

  @@index([tenantId])
}

model ShiftAssignment {
  id        String    @id @default(cuid())
  tenantId  String?
  userId    String
  shiftId   String
  startDate DateTime
  endDate   DateTime?
  notes     String?
  createdAt DateTime  @default(now())

  user  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  shift WorkShift @relation(fields: [shiftId], references: [id], onDelete: Cascade)

  @@index([tenantId, userId])
}

model EmployeeOnboarding {
  id          String    @id @default(cuid())
  tenantId    String?
  userId      String
  type        String    @default("onboarding")
  startDate   DateTime
  targetDate  DateTime?
  status      String    @default("in_progress")
  tasks       Json      @default("[]")
  notes       String?   @db.Text
  createdById String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tenantId, userId])
}

// ═══════════════════════════════════════════════════════════════════
// ─── ERP: Cost Centers & Budgets ─────────────────────────────────
// ═══════════════════════════════════════════════════════════════════

// ═══════════════════════════════════════════════════════════════════
// ─── IT: Asset Registry ──────────────────────────────────────────
// ═══════════════════════════════════════════════════════════════════

model ITAsset {
  id            String    @id @default(cuid())
  tenantId      String?
  name          String
  type          String    @default("hardware") // hardware | software | network | peripheral | other
  serialNumber  String?
  assetTag      String?
  brand         String?
  model         String?
  status        String    @default("active") // active | in_use | maintenance | retired | lost
  assignedToId  String?
  location      String?
  purchaseDate  DateTime?
  purchasePrice Int?
  warrantyEnd   DateTime?
  notes         String?   @db.Text
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, type])
}

// ═══════════════════════════════════════════════════════════════════
// ─── Legal: Billing / Fee Tracking ───────────────────────────────
// ═══════════════════════════════════════════════════════════════════

model LegalFee {
  id            String   @id @default(cuid())
  tenantId      String?
  caseId        String?
  description   String
  feeType       String   @default("fixed") // fixed | hourly | success
  amount        Int      @default(0)
  billableHours Float?
  hourlyRate    Int?
  date          DateTime @default(now())
  status        String   @default("pending") // pending | billed | paid
  invoiceId     String?
  notes         String?  @db.Text
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([tenantId])
  @@index([tenantId, caseId])
  @@index([tenantId, status])
}

model CostCenter {
  id          String   @id @default(cuid())
  tenantId    String?
  code        String
  name        String
  description String?  @db.Text
  parentId    String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  parent   CostCenter?  @relation("CostCenterTree", fields: [parentId], references: [id])
  children CostCenter[] @relation("CostCenterTree")
  budgets  Budget[]

  @@index([tenantId])
  @@unique([tenantId, code])
}

model Budget {
  id           String   @id @default(cuid())
  tenantId     String?
  title        String
  year         Int
  period       String   @default("annual") // annual | q1 | q2 | q3 | q4 | monthly
  month        Int?
  accountId    String?
  costCenterId String?
  amount       Int      @default(0)
  notes        String?  @db.Text
  createdById  String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  account    ChartOfAccount? @relation(fields: [accountId], references: [id])
  costCenter CostCenter?     @relation(fields: [costCenterId], references: [id])

  @@index([tenantId])
  @@index([tenantId, year, period])
}
